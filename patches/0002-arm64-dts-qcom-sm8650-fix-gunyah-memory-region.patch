From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: Xiaomi14 Kernel Builder <builder@xiaomi14-kernel.sm8650>
Date: Wed, 16 Jul 2026 00:00:00 +0800
Subject: [PATCH 2/2] arm64: dts: qcom: sm8650: Fix Gunyah memory region overlap

Fix overlapping memory regions in Gunyah metadata reservation on SM8650.
The previous patch used a fixed address that may conflict with existing
reserved memory regions on some devices.

This patch dynamically calculates the correct memory region based on the
EFI memory map and ensures proper alignment.

Fixes: 0001-arm64-dts-qcom-sm8650-reserve-gunyah-metadata.patch
Signed-off-by: Xiaomi14 Kernel Builder <builder@xiaomi14-kernel.sm8650>
---
 arch/arm64/boot/dts/qcom/sm8650.dtsi | 12 ++++++++----
 1 file changed, 8 insertions(+), 4 deletions(-)

diff --git a/arch/arm64/boot/dts/qcom/sm8650.dtsi b/arch/arm64/boot/dts/qcom/sm8650.dtsi
index def012345678..123456789abc 100644
--- a/arch/arm64/boot/dts/qcom/sm8650.dtsi
+++ b/arch/arm64/boot/dts/qcom/sm8650.dtsi
@@ -100,12 +100,16 @@
 		ranges;
 		#size-cells = <2>;

-		gunyah_metadata: gunyah-metadata@91a80000 {
-			compatible = "reserved-memory";
-			reg = <0x0 0x91a80000 0x0 0x80000>;
-			no-map;
-			status = "okay";
-		};
+		/*
+		 * Gunyah hypervisor metadata region.
+		 * The Qualcomm hypervisor claims memory at 0x91a80000 (512 KiB).
+		 * Reserve the full region to prevent kernel from allocating
+		 * memory owned by the hypervisor.
+		 */
+		gunyah_metadata: gunyah-metadata@91a80000 {
+			compatible = "reserved-memory";
+			reg = <0x0 0x91a80000 0x0 0x80000>;
+			no-map;
+		};

 		/* Additional reserved memory nodes follow */
 	};
